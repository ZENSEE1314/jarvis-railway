# J.A.R.V.I.S. Railway Environment Variables
# Copy to .env or set in Railway dashboard

# Ollama (runs inside the container)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Gemini fallback (optional)
GEMINI_API_KEY=

# User name
JARVIS_USER_NAME=Sir

# Persistent JSON data folder for memory, tasks, logs, agents, and MCP metadata
JARVIS_DATA_DIR=data

# Optional shared token for PC worker endpoints.
# If set on Railway, set the same value locally before running pc_jarvis.py.
JARVIS_WORKER_TOKEN=

# Local PC worker settings
JARVIS_SERVER_URL=https://jarvis-railway-production-42ff.up.railway.app
JARVIS_WORK_DIR=%USERPROFILE%\Documents\Jarvis Work
JARVIS_WORKER_ID=pc-jarvis
JARVIS_WORKER_INTERVAL=20

# Port (Railway sets this automatically)
PORT=7777
